{
  "name": "@conduct/game-rts",
  "version": "0.0.0",
  "type": "module",
  "exports": {
    "./shared": {
      "types": "./dist/shared/index.d.ts",
      "default": "./dist/shared/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "default": "./dist/client/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "default": "./dist/server/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.shared.json && conduct-compile -p tsconfig.client.json && conduct-compile -p tsconfig.server.json",
    "build:shared": "tsc -p tsconfig.shared.json",
    "build:client": "conduct-compile -p tsconfig.client.json",
    "build:server": "conduct-compile -p tsconfig.server.json",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc -p tsconfig.shared.json --noEmit && tsc -p tsconfig.client.json --noEmit && tsc -p tsconfig.server.json --noEmit",
    "dev:server": "conduct-compile -p tsconfig.server.json && node dist/server/index.js",
    "dev:client": "vite"
  },
  "dependencies": {
    "@conduct/ecs": "workspace:*",
    "@conduct/events": "workspace:^",
    "@conduct/networking": "workspace:*",
    "@conduct/renderer": "workspace:*",
    "@conduct/simulation": "workspace:*"
  },
  "devDependencies": {
    "tsx": "^4.0.0",
    "vite": "^6.0.0"
  }
}
